# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# Runtime mode used for Better Auth base URL resolution
# dev/development: falls back to http://localhost:5173 when URLs are empty
# prod/production: requires BETTER_AUTH_URL or ORIGIN
MODE="dev"

# Better Auth base URL (preferred)
BETTER_AUTH_URL=""

# Legacy alias for Better Auth base URL
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# OpenAI (citation generation)
# Required for generating in-text and reference citations in project pages. (Not really needed at this time, I have changed to use Semantic Scholar and some other services :v)
OPENAI_API_KEY=""

# Semantic Scholar API
SEMANTIC_SCHOLAR_API_KEY=""

# Resend (email service for onboarding)
RESEND_API_KEY=""